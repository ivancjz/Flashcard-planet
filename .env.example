ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://flashcard:flashcard@localhost:5432/flashcard_planet

BOT_TOKEN=your_discord_bot_token
DISCORD_APPLICATION_ID=your_discord_application_id
DISCORD_GUILD_ID=
BACKEND_BASE_URL=http://localhost:8000
ADMIN_API_KEY=
SCHEDULER_POLL_SECONDS=300

# Pokemon TCG API
# Optional API key for higher rate limits. Leave blank to use public limits.
POKEMON_TCG_API_BASE_URL=https://api.pokemontcg.io/v2
POKEMON_TCG_API_KEY=
# Provider slots for later cross-provider comparisons.
# Keep provider_1 on the current live source. Leave provider_2 blank until that provider exists.
PROVIDER_1_SOURCE=pokemon_tcg_api
PROVIDER_2_SOURCE=
# Active source used by user-facing price reads, movers, predictions, and alerts.
# Keep this on the source you want to treat as primary; add new providers beside it first.
PRIMARY_PRICE_SOURCE=pokemon_tcg_api
# Comma-separated card IDs to ingest. Defaults target all Base Set Pokemon cards (base1-1 through base1-69).
# If your local .env already defines POKEMON_TCG_CARD_IDS, that override will take precedence.
POKEMON_TCG_CARD_IDS=base1-1,base1-2,base1-3,base1-4,base1-5,base1-6,base1-7,base1-8,base1-9,base1-10,base1-11,base1-12,base1-13,base1-14,base1-15,base1-16,base1-17,base1-18,base1-19,base1-20,base1-21,base1-22,base1-23,base1-24,base1-25,base1-26,base1-27,base1-28,base1-29,base1-30,base1-31,base1-32,base1-33,base1-34,base1-35,base1-36,base1-37,base1-38,base1-39,base1-40,base1-41,base1-42,base1-43,base1-44,base1-45,base1-46,base1-47,base1-48,base1-49,base1-50,base1-51,base1-52,base1-53,base1-54,base1-55,base1-56,base1-57,base1-58,base1-59,base1-60,base1-61,base1-62,base1-63,base1-64,base1-65,base1-66,base1-67,base1-68,base1-69
# Comma-separated set IDs to refresh prices for via the bulk importer scheduler job.
POKEMON_TCG_BULK_SET_IDS=base1,base2,base3,sv3pt5
# Activity-focused trial pool from Scarlet & Violet 151.
# Keep this separate from Base Set so pool metrics can be compared cleanly.
POKEMON_TCG_TRIAL_POOL_LABEL=Scarlet & Violet 151 Trial
POKEMON_TCG_TRIAL_CARD_IDS=sv3pt5-1,sv3pt5-2,sv3pt5-3,sv3pt5-4,sv3pt5-5,sv3pt5-6,sv3pt5-7,sv3pt5-8,sv3pt5-9,sv3pt5-10,sv3pt5-11,sv3pt5-12,sv3pt5-13,sv3pt5-14,sv3pt5-15,sv3pt5-16,sv3pt5-17,sv3pt5-18,sv3pt5-19,sv3pt5-20,sv3pt5-21,sv3pt5-22,sv3pt5-23,sv3pt5-24,sv3pt5-25
# High-activity trial pool from Prismatic Evolutions — RETIRED (2026-04-08).
# The 33-card sv8pt5-148..180 slice has been replaced by High-Activity v2 (13 cards below).
# Left blank so the scheduler no longer ingests these cards by default.
# To restore for comparison, set: POKEMON_TCG_HIGH_ACTIVITY_CARD_IDS=sv8pt5-148,...,sv8pt5-180
POKEMON_TCG_HIGH_ACTIVITY_POOL_LABEL=High-Activity Trial
POKEMON_TCG_HIGH_ACTIVITY_CARD_IDS=
# Run background ingestion automatically when the backend starts.
INGEST_SCHEDULE_ENABLED=true
# Background ingestion interval in hours. Default is 24 hours.
INGEST_INTERVAL_HOURS=24
# Asset history points required before a card is considered sufficiently covered.
GAP_HISTORY_THRESHOLD=7
# Flag sets whose sufficiently covered-card ratio falls below this threshold.
GAP_SET_COVERAGE_THRESHOLD=0.5
# Legacy aliases `POKEMON_TCG_SCHEDULE_ENABLED` and `POKEMON_TCG_SCHEDULE_SECONDS`
# are still accepted if your local environment already uses them.

# AI provider selection
# Supported values: anthropic, groq.
# Default is "anthropic".
LLM_PROVIDER=anthropic

# Anthropic (default provider)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Groq (alternate provider — fast open-weight models)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
