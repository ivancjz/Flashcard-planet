ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://flashcard:flashcard@localhost:5432/flashcard_planet

BOT_TOKEN=your_discord_bot_token
DISCORD_APPLICATION_ID=your_discord_application_id
DISCORD_GUILD_ID=
BACKEND_BASE_URL=http://localhost:8000
SCHEDULER_POLL_SECONDS=300

# Pokemon TCG API
# Optional API key for higher rate limits. Leave blank to use public limits.
POKEMON_TCG_API_BASE_URL=https://api.pokemontcg.io/v2
POKEMON_TCG_API_KEY=
# Comma-separated card IDs to ingest. Defaults target a small Pokemon-only MVP set.
POKEMON_TCG_CARD_IDS=base1-44,base1-58,base1-63
# Keep disabled for local development unless you explicitly want background ingestion.
POKEMON_TCG_SCHEDULE_ENABLED=false
