{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "PostgreSQL (Docker)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "-d"],
      "port": 5432
    },
    {
      "name": "FastAPI Backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "backend.app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "Discord Bot",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "bot.main"],
      "port": null
    }
  ]
}
